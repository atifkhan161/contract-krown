{
  "name": "contract-crown-game",
  "version": "0.2.0",
  "description": "Mobile-first PWA for Contract Crown trick-taking card game",
  "type": "module",
  "main": "src/server/party-server.ts",
  "scripts": {
    "dev": "lsof -ti:1999 | xargs kill -9 2>/dev/null; bun run build:copy && concurrently -n \"CSS,JS,PARTY\" -c \"blue,green,cyan\" \"bun run dev:css\" \"bun run dev:js\" \"bun run dev:party\" --kill-others-on-fail",
    "dev:party": "partykit dev",
    "dev:css": "postcss src/ui/styles/main.css -o dist/client/styles.css --watch --map",
    "dev:js": "bun build src/ui/app.ts --outdir dist/client --target browser --sourcemap=inline --watch",
    "build": "bun run build:client",
    "build:client": "bun run build:js && bun run build:css && bun run build:copy",
    "build:js": "bun build src/ui/app.ts --outdir dist/client --target browser --sourcemap=inline",
    "build:css": "postcss src/ui/styles/main.css -o dist/client/styles.css --no-map",
    "build:copy": "cp public/index.html public/manifest.json dist/client/ && cp -r public/icons public/assets dist/client/",
    "start": "partykit dev",
    "party:dev": "partykit dev",
    "party:deploy": "partykit deploy",
    "test": "bun test",
    "test:unit": "bun test --run",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --project=chromium --ui",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "test:e2e:2h2b": "playwright test one-human-three-bots --project=chromium",
    "test:e2e:2h2b:headed": "playwright test one-human-three-bots --project=chromium --headed",
    "test:e2e:4h": "playwright test four-humans --project=chromium",
    "test:e2e:4h:headed": "playwright test four-humans --project=chromium --headed",
    "lint": "tsc --noEmit && eslint src tests --ext .ts,.tsx"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "daisyui": "^4.12.14",
    "page": "^1.8.7",
    "partysocket": "^1.0.2",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.1.14",
    "@types/page": "^1.8.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "fast-check": "^3.18.0",
    "jsdom": "^29.0.1",
    "partykit": "^0.0.103",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "typescript": "^5.7.2"
  }
}
