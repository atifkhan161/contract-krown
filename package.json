{
  "name": "contract-crown-game",
  "version": "0.1.0",
  "description": "Mobile-first PWA for Contract Crown trick-taking card game",
  "type": "module",
  "main": "src/server/index.ts",
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "build": "bun run build:server && bun run build:client",
    "build:server": "bun build src/server/index.ts --outdir dist/server --target bun",
    "build:client": "bun build src/ui/index.ts --outdir dist/client --target browser",
    "start": "bun run dist/server/index.js",
    "test": "bun test",
    "test:unit": "bun test --run",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "tsc --noEmit && eslint src tests --ext .ts,.tsx"
  },
  "dependencies": {
    "elysia": "^1.1.16",
    "colyseus": "^0.15.23",
    "lokijs": "^1.5.12",
    "page": "^1.8.7",
    "tailwindcss": "^3.4.17",
    "daisyui": "^4.12.14"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/page": "^1.8.3",
    "@types/lokijs": "^1.5.8",
    "typescript": "^5.7.2",
    "eslint": "^8.57.1",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "fast-check": "^3.18.0",
    "vitest": "^2.1.8",
    "tailwindcss": "^3.4.17",
    "daisyui": "^4.12.14"
  },
  "peerDependencies": {
    "typescript": "^5.7.2"
  }
}
