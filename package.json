{
  "name": "contract-crown-game",
  "version": "0.1.0",
  "description": "Mobile-first PWA for Contract Crown trick-taking card game",
  "type": "module",
  "main": "src/server/index.ts",
  "scripts": {
    "dev": "bun run build:copy && concurrently -n \"CSS,JS,SERVER\" -c \"blue,green,yellow\" \"bun run dev:css\" \"bun run dev:js\" \"bun run --watch src/server/serve.ts\" --kill-others-on-fail",
    "dev:css": "postcss src/ui/styles/main.css -o dist/client/styles.css --watch",
    "dev:js": "bun build src/ui/app.ts --outdir dist/client --target browser --sourcemap=inline --watch",
    "build": "bun run build:server && bun run build:client",
    "build:server": "bun build src/server/serve.ts --outdir dist/server --target bun",
    "build:client": "bun run build:js && bun run build:css && bun run build:copy",
    "build:js": "bun build src/ui/app.ts --outdir dist/client --target browser --sourcemap=inline",
    "build:css": "postcss src/ui/styles/main.css -o dist/client/styles.css --no-map",
    "build:copy": "cp public/index.html public/manifest.json dist/client/",
    "start": "bun run dist/server/index.js",
    "test": "bun test",
    "test:unit": "bun test --run",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:e2e:solo": "playwright test one-human-three-bots --project=chromium",
    "test:e2e:multi": "playwright test four-humans --project=chromium",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --project=chromium --ui",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "lint": "tsc --noEmit && eslint src tests --ext .ts,.tsx",
    "postinstall": "node scripts/patch-colyseus.mjs"
  },
  "dependencies": {
    "colyseus": "^0.17.0",
    "@colyseus/sdk": "^0.17.0",
    "daisyui": "^4.12.14",
    "elysia": "^1.1.16",
    "lokijs": "^1.5.12",
    "page": "^1.8.7",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.1.14",
    "@types/lokijs": "^1.5.8",
    "@types/page": "^1.8.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "daisyui": "^4.12.14",
    "eslint": "^8.57.1",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "fast-check": "^3.18.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "typescript": "^5.7.2"
  }
}
